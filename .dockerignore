# =============================================================================
# Mindwall — .dockerignore
# =============================================================================
# Excludes files that should not be copied into the Docker build context.
# =============================================================================

# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
dist/
build/

# Virtual environments
.venv/
venv/
env/

# Test and CI artifacts
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/
.mypy_cache/

# Development data (may contain sensitive test messages)
data/

# Git and version control
.git/
.gitignore
.gitattributes

# IDE and editor configs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Docker files (not needed inside the image)
Dockerfile
docker-compose*.yml
.dockerignore

# Environment files (secrets must come from env vars, not baked into image)
.env
.env.*
!.env.example

# Documentation (README.md is kept — hatchling needs it for the build)
architecture.md

# OS files
.DS_Store
Thumbs.db
desktop.ini
