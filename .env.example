# ===========================================================================
# Mindwall — Environment Configuration Template
# Copy this file to .env and fill in the required values.
# Never commit .env to version control.
# ===========================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=Mindwall
DEBUG=false

# Required: random secret for signing session cookies (min 32 chars)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-that-is-at-least-32-characters-long

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
# Use postgresql+asyncpg:// scheme — asyncpg is required for the async engine
DATABASE_URL=postgresql+asyncpg://mindwall:mindwall@localhost:5432/mindwall

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Session
# ---------------------------------------------------------------------------
# Session cookie lifetime in seconds (default: 1 hour)
SESSION_MAX_AGE=3600

# ---------------------------------------------------------------------------
# Encryption
# ---------------------------------------------------------------------------
# Used to encrypt upstream IMAP/SMTP credentials stored in the database.
# Must be a Fernet-compatible key (URL-safe base64, exactly 44 chars).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-output-of-Fernet.generate_key

# ---------------------------------------------------------------------------
# Ollama — local LLM inference (no cloud APIs)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ---------------------------------------------------------------------------
# Proxy listeners
# ---------------------------------------------------------------------------
IMAP_PROXY_HOST=0.0.0.0
IMAP_PROXY_PORT=1993
# Address shown to users in proxy setup instructions (your server's IP or hostname)
IMAP_PROXY_DISPLAY_HOST=127.0.0.1

SMTP_PROXY_HOST=0.0.0.0
SMTP_PROXY_PORT=1587
# Address shown to users in proxy setup instructions (your server's IP or hostname)
SMTP_PROXY_DISPLAY_HOST=127.0.0.1

# Timeout in seconds for upstream IMAP/SMTP connectivity checks
CONNECTION_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# Local path for encrypted mail blobs and attachments
BLOB_STORAGE_PATH=./data/blobs

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
# Set to false to disable LLM-based analysis (use deterministic checks only)
ANALYSIS_ENABLED=true
# Set to true to enable inline mail-gateway mode (pre-delivery quarantine)
GATEWAY_MODE=false
